#!/usr/bin/env bash
# workspace-memory — shared workspace memory CLI
# Called by Pepper agents to query/update shared context

set -euo pipefail

COMMAND="${1:-}"
shift || true

CLOUD_URL="${PEPPER_CLOUD_URL:?PEPPER_CLOUD_URL not set}"
WS_ID="${WORKSPACE_ID:?WORKSPACE_ID not set}"
AGENT_ID="${AGENT_ID:?AGENT_ID not set}"
SECRET="${PEPPER_EVENT_SECRET:?PEPPER_EVENT_SECRET not set}"
BASE="${CLOUD_URL}/api/workspaces/${WS_ID}/memory"

sign_payload() {
  echo -n "$1" | openssl dgst -sha256 -hmac "$SECRET" -hex 2>/dev/null | awk '{print $NF}'
}

case "$COMMAND" in
  context)
    QUERY="${1:-}"
    if [ -z "$QUERY" ]; then echo "Usage: workspace-memory context \"<task description>\""; exit 1; fi
    PAYLOAD="${WS_ID}:${AGENT_ID}:${QUERY}"
    SIG=$(sign_payload "$PAYLOAD")
    ENCODED_QUERY=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY")
    ENCODED_AGENT=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$AGENT_ID")
    RESPONSE=$(curl -sf --max-time 5 \
      -H "X-Event-Signature: $SIG" \
      "${BASE}/context?task=${ENCODED_QUERY}&agent_id=${ENCODED_AGENT}" 2>/dev/null) || { echo "No context available."; exit 0; }
    echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('context','No context available.'))" 2>/dev/null || echo "$RESPONSE"
    ;;

  search)
    QUERY="${1:-}"
    if [ -z "$QUERY" ]; then echo "Usage: workspace-memory search \"<query>\""; exit 1; fi
    PAYLOAD="${WS_ID}:${AGENT_ID}:${QUERY}"
    SIG=$(sign_payload "$PAYLOAD")
    ENCODED_QUERY=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY")
    ENCODED_AGENT=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$AGENT_ID")
    RESPONSE=$(curl -sf --max-time 5 \
      -H "X-Event-Signature: $SIG" \
      "${BASE}/search?q=${ENCODED_QUERY}&agent_id=${ENCODED_AGENT}" 2>/dev/null) || { echo "Search failed."; exit 0; }
    echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('results','No results found.'))" 2>/dev/null || echo "$RESPONSE"
    ;;

  remember)
    FACT="${1:-}"
    if [ -z "$FACT" ]; then echo "Usage: workspace-memory remember \"<fact or decision>\""; exit 1; fi
    BODY=$(python3 -c "import json,sys; print(json.dumps({'fact': sys.argv[1], 'agent_id': sys.argv[2]}))" "$FACT" "$AGENT_ID")
    SIG=$(sign_payload "$BODY")
    RESPONSE=$(curl -sf --max-time 5 \
      -X POST \
      -H "Content-Type: application/json" \
      -H "X-Event-Signature: $SIG" \
      -d "$BODY" \
      "${BASE}/remember" 2>/dev/null) || { echo "Failed to store. Will retry next time."; exit 0; }
    echo "Stored."
    ;;

  activity)
    PAYLOAD="${WS_ID}:${AGENT_ID}:activity"
    SIG=$(sign_payload "$PAYLOAD")
    ENCODED_AGENT=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$AGENT_ID")
    RESPONSE=$(curl -sf --max-time 5 \
      -H "X-Event-Signature: $SIG" \
      "${BASE}/activity?agent_id=${ENCODED_AGENT}" 2>/dev/null) || { echo "No activity available."; exit 0; }
    echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('activity','No recent activity.'))" 2>/dev/null || echo "$RESPONSE"
    ;;

  *)
    echo "workspace-memory — shared workspace memory"
    echo ""
    echo "Commands:"
    echo "  context \"<description>\"  Get context relevant to a task"
    echo "  search \"<query>\"         Search shared knowledge"
    echo "  remember \"<fact>\"        Store a decision or finding"
    echo "  activity                 View recent team activity"
    exit 1
    ;;
esac
