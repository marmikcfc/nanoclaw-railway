#!/usr/bin/env bash
# delegate — multi-agent task delegation CLI
# Follows the same HMAC-signing pattern as workspace-memory

set -euo pipefail

COMMAND="${1:-}"
shift || true

CLOUD_URL="${PEPPER_CLOUD_URL:?PEPPER_CLOUD_URL not set}"
WS_ID="${WORKSPACE_ID:?WORKSPACE_ID not set}"
AGENT_ID="${AGENT_ID:?AGENT_ID not set}"
SECRET="${PEPPER_EVENT_SECRET:?PEPPER_EVENT_SECRET not set}"
BASE="${CLOUD_URL}/api/workspaces/${WS_ID}/agents/${AGENT_ID}"

sign_payload() {
  echo -n "$1" | openssl dgst -sha256 -hmac "$SECRET" -hex 2>/dev/null | awk '{print $NF}'
}

case "$COMMAND" in
  list)
    CANONICAL="${WS_ID}:${AGENT_ID}:list-peers"
    SIG=$(sign_payload "$CANONICAL")
    RESPONSE=$(curl -sf --max-time 10 \
      -H "X-Event-Signature: $SIG" \
      "${BASE}/list-peers" 2>/dev/null) || { echo "Could not reach workspace. Are you connected?"; exit 1; }
    echo "$RESPONSE" | python3 -c "
import sys, json
d = json.load(sys.stdin)
agents = d.get('agents', [])
if not agents:
    print('No other agents in this workspace.')
    sys.exit(0)
print('{:<38}  {:<20}  {:<30}  {}'.format('ID', 'Name', 'Role', 'Status'))
print('-' * 100)
for a in agents:
    print(f\"{a['id']:<38}  {a.get('agent_name',''):<20}  {a.get('role',''):<30}  {a.get('status','')}\")
" 2>/dev/null || echo "$RESPONSE"
    ;;

  task)
    TO_AGENT=""
    TITLE=""
    DESCRIPTION=""
    SUMMARY=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --to)        TO_AGENT="$2";    shift 2 ;;
        --title)     TITLE="$2";       shift 2 ;;
        --description) DESCRIPTION="$2"; shift 2 ;;
        --summary)   SUMMARY="$2";     shift 2 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
      esac
    done

    if [ -z "$TO_AGENT" ] || [ -z "$TITLE" ] || [ -z "$DESCRIPTION" ] || [ -z "$SUMMARY" ]; then
      echo "Usage: delegate task --to <agent-id> --title <title> --description <desc> --summary <context>"
      exit 1
    fi

    BODY=$(python3 -c "
import json, sys
print(json.dumps({
    'to_agent_id': sys.argv[1],
    'title': sys.argv[2],
    'description': sys.argv[3],
    'context_summary': sys.argv[4],
}))
" "$TO_AGENT" "$TITLE" "$DESCRIPTION" "$SUMMARY")

    SIG=$(sign_payload "$BODY")
    RESPONSE=$(curl -sf --max-time 15 \
      -X POST \
      -H "Content-Type: application/json" \
      -H "X-Event-Signature: $SIG" \
      -d "$BODY" \
      "${BASE}/delegate" 2>/dev/null) || { echo "Delegation failed. Check agent IDs and connectivity."; exit 1; }

    echo "$RESPONSE" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'error' in d:
    print(f\"Error: {d['error']}\")
    sys.exit(1)
print(d.get('message', 'Task delegated.'))
print(f\"Task ID: {d.get('delegated_task_id','')}\")
if not d.get('trigger_ok', True):
    print('Note: push-trigger failed — target agent will pick up task on next wakeup.')
" 2>/dev/null || echo "$RESPONSE"
    ;;

  *)
    echo "delegate — multi-agent task delegation"
    echo ""
    echo "Commands:"
    echo "  list                          List agents in your workspace"
    echo "  task --to <id>                Delegate a task to an agent"
    echo "       --title <title>"
    echo "       --description <what to do>"
    echo "       --summary <what you've done so far>"
    exit 1
    ;;
esac
